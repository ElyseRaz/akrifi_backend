# Base de données (local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=akrifi_db
DB_USER=postgres
DB_PASSWORD=root

# Base de données (Railway – remplace les variables ci-dessus)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT
JWT_SECRET=changez_ce_secret_en_production_avec_une_valeur_aleatoire_longue
JWT_EXPIRES_IN=7d

# Serveur
PORT=3000
NODE_ENV=development

# Upload
MAX_FILE_SIZE=1048576
UPLOAD_DIR=uploads/partitions

# Supabase Storage (laisser vide en dev pour stockage local)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
